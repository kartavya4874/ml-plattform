# ─────────────────────────────────────────────────────────────
# NoCode AI Platform — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the actual .env to version control
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
APP_NAME=NoCode AI Platform
ENVIRONMENT=development
DEBUG=false

# ── Security (REQUIRED: change these before deploying!) ──────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_256_BIT_RANDOM_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── MongoDB ───────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=aiplatform

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO (S3-compatible storage) ────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_DATA=datasets
MINIO_BUCKET_MODELS=models

# ── Email (optional — leave blank to disable) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@nocode-ai.platform

# ── ML Configuration ─────────────────────────────────────────
DEFAULT_TRAINING_TIME_LIMIT=300
MODEL_CACHE_MAX_SIZE=5
